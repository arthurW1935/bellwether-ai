# App
BELLWETHER_APP_NAME=Bellwether API
BELLWETHER_APP_VERSION=0.1.0
BELLWETHER_ENVIRONMENT=development

# CORS
# Comma-separated origins for local or deployed frontend apps.
# Example:
# BELLWETHER_CORS_ORIGINS=http://localhost:3000,https://bellwether.vercel.app
BELLWETHER_CORS_ORIGINS=*

# Crustdata
BELLWETHER_CRUSTDATA_API_KEY=
# Docs currently show both "Bearer" and "Token" styles in examples.
# Supported values should be handled by the client once wired up.
BELLWETHER_CRUSTDATA_AUTH_SCHEME=Bearer
BELLWETHER_CRUSTDATA_BASE_URL=https://api.crustdata.com
BELLWETHER_CRUSTDATA_TIMEOUT_SECONDS=30

# LLM
BELLWETHER_LLM_PROVIDER=litellm
BELLWETHER_GEMINI_API_KEY=
# Inferred LiteLLM model string using LiteLLM provider-prefix conventions
# plus Google's published Gemini base model name `gemini-1.5-flash`.
BELLWETHER_LLM_MODEL=gemini/gemini-1.5-flash
BELLWETHER_LLM_TIMEOUT_SECONDS=30

# Storage
BELLWETHER_DATABASE_URL=sqlite:///./bellwether.db

# Providers
BELLWETHER_USE_MOCK_PROVIDERS=true
BELLWETHER_SEED_DEMO_DATA=true

# Logging
BELLWETHER_LOG_LEVEL=INFO
